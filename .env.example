# Base de donnees
# Par defaut : conteneur MySQL de docker-compose.yml, expose sur le port hote 3307
# (evite le conflit avec un MySQL Laragon/local deja sur 3306).
# Si vous utilisez le MySQL de Laragon au lieu du conteneur Docker, remplacez 3307 par 3306.
DATABASE_URL="mysql://poulet:poulet_dev_password@localhost:3307/poulet_etoile"

# Auth (Better Auth)
# Generer un secret long et aleatoire avant toute mise en production.
BETTER_AUTH_SECRET="dev_local_secret_replace_before_production_32_chars_min"
# Doit correspondre a l'URL/port reellement servi par l'application
# (next dev / next start ecoutent sur 3000 par defaut ; adapter si vous changez de port).
BETTER_AUTH_URL="http://localhost:3000"
