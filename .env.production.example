# Copier vers .env sur le VPS : cp .env.production.example .env

# Image preconstruite publiee par GitHub Actions.
# Surcharger seulement si vous utilisez un autre registre/tag.
APP_IMAGE=ghcr.io/mhdfx/coq-plus:latest

# --- Sans domaine (IP Contabo) — utiliser docker-compose.ip.yml ---
# APP_DOMAIN=212.47.68.171
# BETTER_AUTH_URL=http://212.47.68.171
# NEXT_PUBLIC_APP_URL=http://212.47.68.171

# --- Avec domaine — utiliser docker-compose.prod.yml ---
APP_DOMAIN=app.example.com
APP_EMAIL=admin@example.com
BETTER_AUTH_URL=https://app.example.com
NEXT_PUBLIC_APP_URL=https://app.example.com

# Secret aleatoire long (openssl rand -base64 32)
BETTER_AUTH_SECRET=REMPLACER_PAR_UN_SECRET_DE_32_CARACTERES_MINIMUM

# Requis seulement pour un seed volontaire en production/recette.
SEED_ADMIN_PASSWORD=password
SEED_COMMERCIAL_PASSWORD=password

# IP/CIDR exact du reverse proxy qui definit X-Forwarded-For (adapter au reseau Docker).
# AUTH_TRUSTED_PROXIES=172.20.0.0/24

# --- MySQL (docker-compose.prod.yml) ---
MYSQL_DATABASE=poulet_etoile
MYSQL_USER=poulet
MYSQL_PASSWORD=REMPLACER_MOT_DE_PASSE_FORT
MYSQL_ROOT_PASSWORD=REMPLACER_ROOT_FORT

# NOTE : DATABASE_URL est construit automatiquement par docker-compose
# (docker-compose.prod.yml / docker-compose.ip.yml) a partir des variables
# MYSQL_* ci-dessus — ne PAS le definir ici, une seule source de verite.
